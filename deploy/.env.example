# Copy this file to deploy/.env and fill in real secrets before running
# docker compose. Never commit the filled-in .env file.

POSTGRES_USER=data_explorer
POSTGRES_PASSWORD=change-me
POSTGRES_DB=data_explorer

APP_ENV=production
HTTP_ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=info

# Required in production. Generate with:
#   openssl rand -base64 32
JWT_SIGNING_KEY=
CONNECTION_ENCRYPTION_KEY=
